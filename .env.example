# Server
PORT=5000
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me

# PostgreSQL (local dev: postgres://user:password@localhost:5432/compliance_marketplace)
DATABASE_URL=postgres://user:password@localhost:5432/compliance_marketplace

# CORS — exact origin of the frontend (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# AWS — create an IAM user with S3 PutObject/GetObject/DeleteObject on the KYC bucket only
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-kyc-bucket-name
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=replace_me
